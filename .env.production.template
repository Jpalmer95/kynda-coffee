# === Kynda Coffee — Production Environment Template ===
# Copy this to .env.production and fill in real values on the server.
# NEVER commit .env.production to Git.

# ---- App ----
NEXT_PUBLIC_APP_URL=https://kyndacoffee.com
NEXT_PUBLIC_APP_NAME="Kynda Coffee"

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Stripe (Live) ----
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- Square (Production) ----
SQUARE_ACCESS_TOKEN=EAAA...
SQUARE_ENVIRONMENT=production
SQUARE_APPLICATION_ID=sq0idp-...
SQUARE_LOCATION_ID=...
SQUARE_WEBHOOK_SIGNATURE_KEY=...

# ---- Email (Resend) ----
RESEND_API_KEY=re_...
FROM_EMAIL=hello@kyndacoffee.com

# ---- SMS (Twilio) ----
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ---- AI Image Generation (FAL) ----
FAL_KEY=...

# ---- Printful (POD) ----
PRINTFUL_API_KEY=...

# ---- Push Notifications ----
NEXT_PUBLIC_VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
